  "components": {
    "schemas": {
      "CurrentUserResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "User id."
          },
          "email": {
            "type": "string",
            "title": "Email",
            "description": "User email."
          },
          "role": {
            "$ref": "#/components/schemas/Role",
            "description": "Resolved RBAC role."
          },
          "employee_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Employee Id",
            "description": "Linked employee id, if any."
          }
        },
        "type": "object",
        "required": ["id", "email", "role"],
        "title": "CurrentUserResponse"
      },
      "EmployeeResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Prefixed employee id."
          },
          "employee_no": {
            "type": "string",
            "title": "Employee No",
            "description": "Stable employee number."
          },
          "first_name": {
            "type": "string",
            "title": "First Name",
            "description": "Employee first name."
          },
          "last_name": {
            "type": "string",
            "title": "Last Name",
            "description": "Employee last name."
          },
          "email": {
            "type": "string",
            "title": "Email",
            "description": "Employee work email."
          },
          "department_id": {
            "type": "string",
            "title": "Department Id",
            "description": "Department id."
          },
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Job title."
          },
          "manager_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Manager Id",
            "description": "Direct manager employee id."
          },
          "employment_type": {
            "$ref": "#/components/schemas/EmploymentType",
            "description": "Employment type."
          },
          "hire_date": {
            "type": "string",
            "format": "date",
            "title": "Hire Date",
            "description": "Hire date."
          },
          "birth_date": {
            "type": "string",
            "format": "date",
            "title": "Birth Date",
            "description": "Birth date used only for statutory leave defaults."
          },
          "status": {
            "$ref": "#/components/schemas/EmployeeStatus",
            "description": "Employee lifecycle status."
          },
          "termination_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Termination Date",
            "description": "Termination date if terminated."
          }
        },
        "type": "object",
        "required": [
          "id",
          "employee_no",
          "first_name",
          "last_name",
          "email",
          "department_id",
          "title",
          "employment_type",
          "hire_date",
          "birth_date",
          "status"
        ],
        "title": "EmployeeResponse"
      },
      "EmployeeStatus": {
        "type": "string",
        "enum": ["active", "on_leave", "terminated"],
        "title": "EmployeeStatus"
      },
      "EmploymentType": {
        "type": "string",
        "enum": ["full_time", "part_time", "contractor"],
        "title": "EmploymentType"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LeaveBalanceResponse": {
        "properties": {
          "employee_id": {
            "type": "string",
            "title": "Employee Id",
            "description": "Employee id."
          },
          "year": {
            "type": "integer",
            "title": "Year",
            "description": "Balance year."
          },
          "entitled_days": {
            "type": "integer",
            "title": "Entitled Days",
            "description": "Annual entitlement days."
          },
          "carried_over": {
            "type": "integer",
            "title": "Carried Over",
            "description": "Carried-over days."
          },
          "used_days": {
            "type": "integer",
            "title": "Used Days",
            "description": "Approved used days."
          },
          "pending_days": {
            "type": "integer",
            "title": "Pending Days",
            "description": "Pending days."
          },
          "remaining": {
            "type": "integer",
            "title": "Remaining",
            "description": "Computed remaining days."
          }
        },
        "type": "object",
        "required": [
          "employee_id",
          "year",
          "entitled_days",
          "carried_over",
          "used_days",
          "pending_days",
          "remaining"
        ],
        "title": "LeaveBalanceResponse"
      },
      "LeaveRequestCreate": {
        "properties": {
          "employee_id": {
            "type": "string",
            "title": "Employee Id",
            "description": "Requester employee id."
          },
          "type": {
            "$ref": "#/components/schemas/LeaveType",
            "description": "Leave type."
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "title": "Start Date",
            "description": "Start date."
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "title": "End Date",
            "description": "End date."
          },
          "note": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 500
              },
              {
                "type": "null"
              }
            ],
            "title": "Note",
            "description": "Optional requester note."
          }
        },
        "type": "object",
        "required": ["employee_id", "type", "start_date", "end_date"],
        "title": "LeaveRequestCreate"
      },
      "LeaveRequestPage": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/LeaveRequestResponse"
            },
            "type": "array",
            "title": "Items",
            "description": "Leave request page items."
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo",
            "description": "Cursor page metadata."
          }
        },
        "type": "object",
        "required": ["items", "page"],
        "title": "LeaveRequestPage"
      },
      "LeaveRequestResponse": {
        "properties": {
          "id": {
