{
  "name": "origin-ms",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "typecheck": "corepack pnpm --filter @origin-ms/frontend typecheck",
    "biome": "biome check .",
    "depcruise": "depcruise frontend/src --config .dependency-cruiser.cjs",
    "unit": "vitest run",
    "storybook": "storybook dev -p 6006 --ci",
    "storybook:build": "storybook build",
    "gen:api": "openapi-ts --input ./backend/openapi.json --output frontend/src/api/generated --client @hey-api/client-fetch --plugins @hey-api/typescript @hey-api/sdk @tanstack/react-query",
    "contract-drift": "node scripts/check-contract-drift.mjs",
    "phase0:preflight": "node scripts/check-phase0-preconditions.mjs",
    "playwright": "corepack pnpm phase0:preflight && playwright test",
    "ci": "corepack pnpm phase0:preflight && corepack pnpm typecheck && corepack pnpm biome && corepack pnpm depcruise && corepack pnpm unit && corepack pnpm contract-drift && corepack pnpm playwright"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-focus-scope": "^1.1.11",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.13",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "motion": "^12.23.26",
    "next": "^16.1.0",
    "nuqs": "^2.8.1",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.69.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@hey-api/openapi-ts": "^0.99.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/nextjs-vite": "10.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "^17.3.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.57.0",
    "storybook": "^10.1.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
